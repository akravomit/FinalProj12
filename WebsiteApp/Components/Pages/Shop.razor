@page "/Shop"
@using DBL
@using Models
@inject NavigationManager NavMan
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using WebsiteApp
@inject ProtectedSessionStorage Session

<ul>
    @if (LoggedUser is not null)
    {
        <li>
            <button @onclick="Back" class="perma_name generic-btn">
                Go back to the lobby
            </button>
        </li>

        @if (Selected is not null)
        {
            <navname>
                <div class="perma_name generic-btn">
                    Shopping as @Selected.name
                </div>
            </navname>
        }
        <navname>
            <div class="perma_name generic-btn">
                The Shop
            </div>
        </navname>
    }
</ul>

<table>
    @if (Selected is not null)
    {
        <td style="background-color:rgba(51, 51, 51, 0.25); max-width:300px; max-height:80%;">
            <button class="generic-btn" style="padding:10px;">
                <div style="font-family:Forte; text-align:center; font-size:30px;">
                    @Selected.name
                </div>
                <div style="font-family:Forte; text-align:center; font-size:20px;">
                    You have: @Selected.coins coins
                </div>
            </button>
        </td>
        <td style="background-color:rgba(51, 51, 51, 0.25); max-width:500px; max-height:800px">
            <div class="generic-btn" style="padding:10px;">
                <div style="font-family:Verdana; font-size:20px;">
                    Player's inventory is here:
                </div>
            </div>
            @foreach (Dictionary<string, object> item in PlayerFullInv)
            {
                @if (!(bool)item["Inv_IsHidden"] && !(bool)(item["Itm_IsHidden"]))
                {
                    <div class="dropdown" style="padding: 5px 5px 5px 5px;">
                        <div class="perma_name dropbtn" style="font-family:Verdana">
                            @item["Name"] - @item["Amount"]/@item["MaxStack"] | Level @item["Item_Level"]
                        </div>
                    </div>
                }
            }
        </td>
        <td style="background-color:rgba(51, 51, 51, 0.25); max-width:1000px; max-height:800px">
            <div class="generic-btn" style="padding:10px;">
                <div style="font-family:Verdana; font-size:20px;">
                    Items in the shop
                </div>
            </div>
            <form @onsubmit="GetItemsBySimilar" style="padding: 20px 0px 20px 0px;">
                <label for="itmLookup" class="generic-btn">Look up items, the more letters the more specific</label>
                <input type="search" class="generic-btn" @bind-value="searchterm" id="itmLookup" />
                <input type="submit" class="generic-btn" value="Search for items" />
            </form>
            <br />
            @if(SearchResults is not null)
            {
                <div style="display:flex; flex-flow: row wrap; overflow:auto; max-width:800px; max-height:60%;">
                    @foreach (Item itm in SearchResults)
                    {
                        <div class="dropdown" style="padding: 10px 5px 40px 5px;">
                            @if (!itm.is_hidden)
                            {
                                @if (SelectedItem is not null && itm.id == SelectedItem.id)
                                {
                                    <div class="perma_name dropbtn" @onclick="() => SelectItem(itm)" style="background-color:#1dd3e2;">
                                        @itm.name - @itm.value coins
                                    </div>
                                }
                                else
                                {
                                    <div class="perma_name dropbtn" @onclick="() => SelectItem(itm)">
                                        @itm.name - @itm.value coins
                                    </div>
                                }
                            }
                        </div>
                    }
                </div>
            }
            else if (SearchResults is not null && SearchResults.Count == 0)
            {
                <div class="generic-btn" style="padding:10px;">
                    <div style="font-family:Verdana; font-size:20px;">
                        Oops! Looks like we found nothing. Try and make your search less specific
                    </div>
                </div>
            }
        </td>
        <td style="background-color:rgba(51, 51, 51, 0.25); max-width:300px; max-height:800px">
            @if (SelectedItem is not null)
            {
                <div class="generic-btn">
                    <div class="perma_name">
                        @SelectedItem.name - @SelectedItem.value coins
                    </div>
                    <div style="font-family:Verdana; font-size:20px;">
                        @Item_Type_Names[SelectedItem.item_type].name | Rated at @GetRarityString(SelectedItem.rarity) stars <br /> <br />
                        "@SelectedItem.description"
                    </div>
                </div>
                <form @onsubmit="() => PurchaseItem(SelectedItem,PurchaseAmount)" class="generic-btn">
                    <label for="Amount">Amount of the item to buy (max amount: @(Selected.coins/SelectedItem.value))</label>
                    <input type="range" @bind-value="PurchaseAmount" name="Amount" min="1" max="@(Selected.coins/SelectedItem.value)" />
                    <input class="generic-btn" type="submit" value="Buy the item @PurchaseAmount time/s, will cost @(SelectedItem.value + SelectedItem.value*PurchaseAmount)" />
                </form>
                @* <button class="perma_name generic-btn" @onclick="() => PurchaseItem(SelectedItem,1)">
                    Buy this item (will cost x coins)
                </button> *@
            }
        </td>
    }
</table>

@code {
    User LoggedUser; List<Player> Playerlist; Player Selected;
    List<Dictionary<string, object>> PlayerFullInv; string searchterm; List<Item> SearchResults; Item SelectedItem;
    List<Item_Type_Name> Item_Type_Names; int PurchaseAmount = 1;
    [Inject] IJSRuntime JS { get; set; } = default!;
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var tmp = await Session.GetAsync<User>("Logged user");
            if (tmp.Success)
            {
                LoggedUser = tmp.Value;
                Playerlist = await Middleman.GetPlayers(LoggedUser.id);
            }
            var tmp2 = await Session.GetAsync<Player>("Selected player");
            if (tmp2.Success)
            { 
                Selected = tmp2.Value; 
                PlayerFullInv = await Middleman.NewGetInvOfPlayer(Selected);
            }
            SearchResults = await Middleman.GetItemsBySimilar(searchterm);
            Item_Type_Names = await Middleman.GetAllItem_Type_Names();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            await GoToHome();
        }
    }
    private async Task Back() { NavMan.NavigateTo("/Lobby"); }
    private async Task GoToHome() { NavMan.NavigateTo("/"); }
    private async Task Select_Player(Player plr)
    {
        Selected = new Player(plr);
        PlayerFullInv = new List<Dictionary<string, object>>();
        PlayerFullInv = await Middleman.NewGetInvOfPlayer(Selected);
        StateHasChanged();
    }
    private async Task Goto(char dest)
    {
        switch (dest)
        {

        }
    }
    private async Task PurchaseItem(Item item, int AmountBought)
    {
        Player player2 = new Player(Selected);
        player2.coins -= (item.value * AmountBought);
        await Middleman.UpdatePlayer(Selected, player2);
        await Middleman.GiveItem(item.id, Selected, AmountBought);
        PlayerFullInv = await Middleman.NewGetInvOfPlayer(Selected);
        Selected = await Middleman.GetPlayerByItsID(Selected.id);
        await InvokeAsync(StateHasChanged);
    }
    private async Task GetItemsBySimilar()
    {
        SearchResults = await Middleman.GetItemsBySimilar(searchterm);
        await InvokeAsync(StateHasChanged);
    }
    private async Task SelectItem(Item item)
    {
        if (SelectedItem is null || SelectedItem.id != item.id)
        {
            SelectedItem = new Item(item);
        }
        else
        {
            SelectedItem = null;
        }
        await InvokeAsync(StateHasChanged);
    }
    private string GetRarityString(int Rarity)
    {
        string ret = string.Empty;
        for (int i = 0; i < Rarity; i++)
        {
            ret += "⭐";
        }
        return ret;
    }
}
