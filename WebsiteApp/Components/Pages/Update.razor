@page "/Update"
@using DBL
@using Models
@inject NavigationManager NavMan
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject ProtectedSessionStorage Session

<h1 class="header">Update your user data</h1>

@if (!UserDoesExist)
{
    <iframe width="640"
            height="480"
            src="https://www.youtube.com/embed/WFg0vTeXhWs"
            title="Oh, Hi mr frog :)"
            frameborder="0"
            allow="autoplay; fullscreen;">
    </iframe>
    <button class="generic-btn" @onclick="() => NavMan.NavigateTo(Login)">
        <div class="perma_name">Go to the login page.<br />You are not logged in >:( </div>
    </button>
}
else
{
    <form @onsubmit="UpdateUser" style="font-size:20px; font-family:Forte;"> Update your user
        <input class="generic-btn" type="text" placeholder="Enter an updated username, if you want to update it" @bind-value="username" style="font-size:20px; font-family:Forte;" />
        <input class="generic-btn" type="password" pattern="(?=.*[A-Z]).{6,20}" placeholder="Enter an updated password, if you want to update it" title="Password must be between 6 and 20 characters long and contain at least one uppercase letter" @bind-value="password" style="font-size:20px; font-family:Forte;" />
        <input class="generic-btn" type="email" pattern="[a-z0-9._%+-]+@@[a-z0-9.-]+\.[a-z]{2,}$" placeholder="Your email goes here" @bind-value="email" required title="Your email goes here for verification purposes" style="font-size:20px; font-family:Forte;" />
        <button type="submit" class="generic-btn" style="font-size:20px; font-family:Forte;">
            Update your user
        </button>
        <button type="button" class="generic-btn" style="font-size:20px; font-family:Forte;" @onclick="Back">
            Go back
        </button>
        <button type="button" class="generic-btn" style="font-size:20px; font-family:Forte;" onclick="Confirmation">

        </button>
    </form>
}

<script>
    function Confirmation(){
        confirm("Are you SURE you want to delete your user? This action is permanent!"):@Delete();
    }
</script>

@code {
    User LoggedUser;
    UserDB UDB;
    bool UserDoesExist;
    string username; string password; string email; string Login = "Login";
    protected override async Task OnInitializedAsync()
    {
        var tmp = await Session.GetAsync<User>("Logged user");
        if (tmp.Success) { LoggedUser = tmp.Value; }
        UserDoesExist = await Middleman.DoesUserExist_ByKey_Async("username", LoggedUser.username);
        UDB = new UserDB();
    }
    private async Task Back() { NavMan.NavigateTo("/"); }
    private async Task Delete() 
    { 
        await Middleman.DeleteUser(LoggedUser); 
        await Log_Out_Async(); 
    }
    private async Task Log_Out_Async()
    {
        await Session.DeleteAsync("Logged user");
        LoggedUser = null;
        UserDoesExist = false;
        await Back();
    }
    private async Task UpdateUser()
    {
        User toupdate = new User(username, password, LoggedUser.email);
        await UDB.Update_Async(LoggedUser, toupdate);
        LoggedUser = new User(toupdate);
        await Session.SetAsync("Logged user", LoggedUser);
        await InvokeAsync(StateHasChanged);
    }
}
