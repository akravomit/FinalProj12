@page "/Players"
@using DBL
@using Models
@inject NavigationManager NavMan
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject ProtectedSessionStorage Session

<h1 class="header">Select a Player from the ones you made</h1>
<table style="width: 100%; margin: 0 auto; border-collapse: collapse;">
    <tr colspan="100%">
        @if (UserDoesExist)
        {
            <div class="button-container">
                @if (Playerlist is not null)
                {
                    @foreach (Player pingle_pongle in Playerlist)
                    {
                        <button class="generic-btn" @onclick="() => SelectPlayerAndGoToTheDungeon(pingle_pongle)">
                            <div class="perma_name">
                                @pingle_pongle.name <br />
                                <div style="font-size:20px">
                                    HP: @pingle_pongle.hp | Mana: @pingle_pongle.mana <br />
                                    @pingle_pongle.name.Split([' ', ',', '-', '<', '>', '(', ')'])[0] has @pingle_pongle.coins coins
                                    @*Name trimming, luh mao am I bored*@
                                </div>
                            </div> @* @onmouseover="() => IAmCreativelyBankruptINeedNameIdeas(pingle_pongle)" *@
                        </button>
                    }
                }
                else
                {
                    <div class="generic-btn">
                        <div class="perma_name">
                            You have no characters!<br />Make one!
                        </div>
                    </div>
                }
                
            </div>
        }
        else
        {
            <iframe width="640"
                    height="480"
                    src="https://www.youtube.com/embed/WFg0vTeXhWs"
                    title="Oh, Hi mr frog :)"
                    frameborder="0"
                    allow="autoplay; fullscreen;">
            </iframe>
            <button class="generic-btn" @onclick="() => NavMan.NavigateTo(Login)">
                <div class="perma_name">Go to the login page.<br />You are not logged in >:( </div>
            </button>
        }
    </tr>
    @if (UserDoesExist)
    {
        <tr colspan="100%">
            <button class="generic-btn">
                <div class="perma_name"><input @bind-value="playername_for_the_fucntion__CreatePlayerAndInsertPlayerToTheDatabaseWhenYouPressThisButtonButtonWithTheButtonTagBecauseApparentlyYouNeedToInsertAPlayerToTheDatabaseViaARazorPage_NoClueWhyWouldSomeoneDoThatThoughItIsNotAFishAnt" placeholder="Enter a name for a new player"></input></div>
            </button>
            <button class="generic-btn" @onclick="Create_Player_And_Insert_Player_To_The_Database_When_You_Press_This_Button_Button_With_The_Button_Tag_Because_Apparently_You_Need_To_Insert_A_Player_To_The_Database_Via_A_Razor_Page___No_Clue_Why_Would_Someone_Do_That_Though_It_Is_Not_A_Fish_Ant">
                @if (response is null)
                {
                    <div class="perma_name">
                        Create the character!
                    </div>
                }
                else
                {
                    <div class="perma_name">
                        @response
                    </div>
                }
            </button>
            <button class="generic-btn" @onclick="Back">
                <div class="perma_name">Go back to the main page</div>
            </button>

        </tr>
    }
</table>

@code {
    User LoggedUser;
    List<Player> Playerlist;
    bool UserDoesExist;
    private string eye = "<o>"; private string Login = "Login"; private string response = null; private List<string> Player_Display_String = new List<string>();
    string playername_for_the_fucntion__CreatePlayerAndInsertPlayerToTheDatabaseWhenYouPressThisButtonButtonWithTheButtonTagBecauseApparentlyYouNeedToInsertAPlayerToTheDatabaseViaARazorPage_NoClueWhyWouldSomeoneDoThatThoughItIsNotAFishAnt;
    protected override async Task OnInitializedAsync()
    {

    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var tmp = await Session.GetAsync<User>("Logged user");
            if (tmp.Success) 
            { 
                LoggedUser = tmp.Value; 
                UserDoesExist = await Middleman.DoesUserExist_ByKey_Async("username", LoggedUser.username);
                Playerlist = await Middleman.GetPlayers(LoggedUser.id);
            }
            else { UserDoesExist = false; }
            await InvokeAsync(StateHasChanged);
        }
    }
    private async Task Back() { NavMan.NavigateTo("/"); }
    private async Task Log_Out_Async()
    {
        await Session.DeleteAsync("Logged user");
        LoggedUser = null;
        UserDoesExist = false;
        await Back();
    }
    private async Task SelectPlayerAndGoToTheDungeon(Player p)
    {
        await Session.SetAsync("Selected player", p);
        NavMan.NavigateTo("/Dungeon");
    }
    private async Task Create_Player_And_Insert_Player_To_The_Database_When_You_Press_This_Button_Button_With_The_Button_Tag_Because_Apparently_You_Need_To_Insert_A_Player_To_The_Database_Via_A_Razor_Page___No_Clue_Why_Would_Someone_Do_That_Though_It_Is_Not_A_Fish_Ant()
    {
        Player result = await Middleman.InsertGetPlayer(playername_for_the_fucntion__CreatePlayerAndInsertPlayerToTheDatabaseWhenYouPressThisButtonButtonWithTheButtonTagBecauseApparentlyYouNeedToInsertAPlayerToTheDatabaseViaARazorPage_NoClueWhyWouldSomeoneDoThatThoughItIsNotAFishAnt.Substring(0,20), LoggedUser.id);
        if (result is null) { response = "This character already exists! Check its name and try again."; }
        else { response = $"{result.name} has been inserted into the database! Enjoy."; }
    }
    private async Task IAmCreativelyBankruptINeedNameIdeas(Player p)
    {
        Player_Display_String.Add($"HP: {p.hp} | Mana: {p.mana}");
        Player_Display_String.Add($"{p.name.Split([' ', ',', '-', '<', '>', '(', ')'])[0]} has {p.coins} coins");
    }
}
