@page "/Players"
@using DBL
@using Models
@inject NavigationManager NavMan
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject ProtectedSessionStorage Session

<h1 class="header">Select a Player from the ones you made</h1>
<table style="width: 100%; margin: 0 auto; border-collapse: collapse;">
    <tr colspan="100%">
        @if (UserDoesExist)
        {
            <div class="button-container">
                @if (Playerlist is not null)
                {
                    @foreach (Player pingle_pongle in Playerlist)
                    {
                        <button class="generic-btn">
                            <div class="name">@pingle_pongle.name</div>
                            <div class="tooltip">
                                HP: @pingle_pongle.hp | Mana: @pingle_pongle.mana <br/>
                                @pingle_pongle.name.Split([' ', ',', '-', '<', '>', '(', ')'])[0] has @pingle_pongle.coins coins
                                @*Name trimming, luh mao*@
                            </div>
                        </button>
                    }
                }
                else
                {
                    <div class="generic-btn">
                        <div class="perma_name">
                            You have no characters!<br />Make one!
                        </div>
                    </div>
                }
                
            </div>
        }
        else
        {
            <iframe width="640"
                    height="480"
                    src="https://www.youtube.com/embed/WFg0vTeXhWs"
                    title="Oh, Hi mr frog :)"
                    frameborder="0"
                    allow="autoplay; fullscreen;">
            </iframe>
            <button class="generic-btn" @onclick="() => NavMan.NavigateTo(Login)">
                <div class="perma_name">Go to the login page.<br />You are not logged in >:( </div>
            </button>
        }
    </tr>
    <tr colspan="100%">
        <button class="generic-btn">
            <div class="name">Make a character!</div>
            <div class="tooltip">
                <input @bind-value="playername_for_the_fucntion__CreatePlayerAndInsertPlayerToTheDatabaseWhenYouPressThisButtonButtonWithTheButtonTagBecauseApparentlyYouNeedToInsertAPlayerToTheDatabaseViaARazorPage_NoClueWhyWouldSomeoneDoThatThoughItIsNotAFishAnt" placeholder="Enter your player name"></input>
            </div>
        </button>
        <button class="generic-btn" @onclick="CreatePlayerAndInsertPlayerToTheDatabaseWhenYouPressThisButtonButtonWithTheButtonTagBecauseApparentlyYouNeedToInsertAPlayerToTheDatabaseViaARazorPage_NoClueWhyWouldSomeoneDoThatThoughItIsNotAFishAnt">
            @if (response is null)
            {
                <div class="perma_name">
                    Create the character!
                </div>
            }
            else
            {
                <div class="perma_name">
                    @response
                </div>
            }
        </button>
        <button class="generic-btn" @onclick="Back">
            <div class="perma_name">Go back to the main page</div>
        </button>

    </tr>
</table>

@code {
    User LoggedUser;
    List<Player> Playerlist; Player SelectedPlayer;
    bool UserDoesExist;
    private string eye = "<o>"; private string Login = "Login"; private string response = null;
    string playername_for_the_fucntion__CreatePlayerAndInsertPlayerToTheDatabaseWhenYouPressThisButtonButtonWithTheButtonTagBecauseApparentlyYouNeedToInsertAPlayerToTheDatabaseViaARazorPage_NoClueWhyWouldSomeoneDoThatThoughItIsNotAFishAnt;
    protected override async Task OnInitializedAsync()
    {

    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var tmp = await Session.GetAsync<User>("Logged user");
            if (tmp.Success) 
            { 
                LoggedUser = tmp.Value; 
                UserDoesExist = await Middleman.DoesUserExist_ByKey_Async("username", LoggedUser.username);
                Playerlist = await Middleman.GetPlayers(LoggedUser.id);
            }
            else { UserDoesExist = false; }
            await InvokeAsync(StateHasChanged);
        }
    }
    private async Task Back() { NavMan.NavigateTo("/"); }
    private async Task Log_Out_Async()
    {
        await Session.DeleteAsync("Logged user");
        LoggedUser = null;
        UserDoesExist = false;
        await InvokeAsync(StateHasChanged);
    }
    private async Task CreatePlayerAndInsertPlayerToTheDatabaseWhenYouPressThisButtonButtonWithTheButtonTagBecauseApparentlyYouNeedToInsertAPlayerToTheDatabaseViaARazorPage_NoClueWhyWouldSomeoneDoThatThoughItIsNotAFishAnt()
    {
        Player result = await Middleman.InsertGetPlayer(playername_for_the_fucntion__CreatePlayerAndInsertPlayerToTheDatabaseWhenYouPressThisButtonButtonWithTheButtonTagBecauseApparentlyYouNeedToInsertAPlayerToTheDatabaseViaARazorPage_NoClueWhyWouldSomeoneDoThatThoughItIsNotAFishAnt.Substring(0,20), LoggedUser.id);
        if (result is null) { response = "This character already exists! Check its name and try again."; }
        else { response = $"{result.name} has been inserted into the database! Enjoy."; }
    }
}
