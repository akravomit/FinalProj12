</style>

@code {
    enum ScreenMode { Users, Monsters, Items, Misc }
    ScreenMode smode = ScreenMode.Users;
    List<User> AllUsers; List<Player> UsersPlayers; List<Dictionary<string, object>> PlayersInv; List<Dictionary<string, object>> PlayersEntries; Inventory SelectedItem;
    User LoggedUser; User SelectedUser; Player SelectedPlayer;
    string searchterm; List<Item> ItemsFound; Item SelectedResult;
    List<Monster> AllMonsters; Monster SelectedMonster; Monster Shadow; Monster MonsterDummy = new Monster();
    List<Item> AllItems; Item PickedItem; Item ShadowItem; Item ItemDummy = new Item();
    List<Item_Attacks> ItemAttacks; Item_Attacks SelectedItemAttack; Item_Attacks ShadowItemAttack; Item_Attacks ItemAttackDummy = new Item_Attacks();
    List<Monster_Attacks> MonsterAttacks; Monster_Attacks SelectedMonsterAttack; Monster_Attacks ShadowMonsterAttack; Monster_Attacks MonsterAttackDummy = new Monster_Attacks();
    List<Attack> AllAttacks; Attack SelectedAttack; Attack ShadowAttack; Attack AttackDummy = new Attack();
    List<Element> Elements; List<Item_Type_Name> ItemTypeNames;
    [Inject] IJSRuntime JS { get; set; } = default!;
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var tmp = await Session.GetAsync<User>("Logged user");
            if (tmp.Success)
            {
                LoggedUser = tmp.Value;
                if (!LoggedUser.isadmin) { await Back(); }
            }
        }
        catch (Exception ex)
        {
            await Task.Delay(150);
            await Back();
        }
    } //Gets the logged user and verifies logged user is an admin
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            AllUsers = await Middleman.GetAllUsers();
            AllMonsters = await Middleman.GetMonsters(true);
            AllItems = await Middleman.GetAllItems();
            Elements = await Middleman.GetAllElements();
            ItemTypeNames = await Middleman.GetAllItem_Type_Names();
            AllAttacks = await Middleman.GetAllAttacks();
            StateHasChanged();
        }
    } //Gets all users to manage
    private async Task Back() { NavMan.NavigateTo("/"); }
    private async Task DeleteUser(User user)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this user?");
        if (confirmed) { await Middleman.DeleteUser(user); }
        await PostActionCleanup();
    }
    private async Task RestoreUser(User user)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to restore this user?");
        if (confirmed) { await Middleman.UnDeleteUser(user); }
        await PostActionCleanup();
    }
    private async Task PostActionCleanup()
    {
        AllUsers = await Middleman.GetAllUsers();
        await InvokeAsync(StateHasChanged);
    }
    private async Task Log_Out_Async()
    {
        await Session.DeleteAsync("Logged user");
        LoggedUser = null;
        await InvokeAsync(StateHasChanged);
    }
    private async Task SelectUser(User u)
    {
        SelectedUser = new User(); UsersPlayers = new List<Player>(); PlayersEntries = new List<Dictionary<string, object>>(); PlayersInv = new List<Dictionary<string, object>>();
        SelectedUser = new User(u);
        UsersPlayers = await Middleman.GetPlayers(u);
        await InvokeAsync(StateHasChanged);
    }
    private async Task SelectPlayer (Player p)
    {
        SelectedPlayer = new Player(); PlayersEntries = new List<Dictionary<string, object>>(); PlayersInv = new List<Dictionary<string, object>>();
        //Clears previous data
        SelectedPlayer = new Player(p);
        PlayersEntries = await Middleman.NewGetEntriesOfPlayer(p);
        PlayersInv = await Middleman.NewGetInvOfPlayer(p);
        await InvokeAsync(StateHasChanged);
    }
    private async Task DeselectPlayer (Player p)
    {
        SelectedPlayer = null; SelectedItem = null; PlayersEntries = null; PlayersInv = null;
        await InvokeAsync(StateHasChanged);
    }
    private async Task SelectItem(Dictionary<string, object> dict)
    {
        SelectedItem = new Inventory(await ItemDictToInv(dict));
        await InvokeAsync(StateHasChanged);
    }
    private async Task DeselectItem(Dictionary<string,object> dict)
    {
        SelectedItem = null;
        await InvokeAsync(StateHasChanged);
    }
    private async Task<Inventory> ItemDictToInv(Dictionary<string, object> dict)
    {
        Inventory inventory = new Inventory(
            Convert.ToInt32(dict["InventoryID"]), 
            Convert.ToInt32(dict["PlayerID"]), 
            Convert.ToInt32(dict["ItemID"]), 
            Convert.ToInt32(dict["Item_Level"]), 
            Convert.ToBoolean(dict["Inv_IsHidden"]), 
            Convert.ToInt32(dict["Amount"])
        );
        return inventory;
    }
    private async Task DeleteItem(Dictionary<string,object> dict)
    {
        Inventory inv = new Inventory(await ItemDictToInv(dict));
        Inventory inv2 = new Inventory(inv); 
        inv2.IsHidden = true;
        await Middleman.UpdateInv(inv, inv2);
        PlayersInv = await Middleman.NewGetInvOfPlayer(SelectedPlayer);
        await InvokeAsync(StateHasChanged);
    }
    private async Task RestoreItem(Dictionary<string,object> dict)
    {
        Inventory inv = new Inventory(await ItemDictToInv(dict));
        Inventory inv2 = new Inventory(inv); inv2.IsHidden = false;
        await Middleman.UpdateInv(inv, inv2);
        PlayersInv = await Middleman.NewGetInvOfPlayer(SelectedPlayer);
        await InvokeAsync(StateHasChanged);
    }
    private async Task DeletePlayer(Player p)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this player? This action cannot be undone!");
        if (confirmed) 
        { 
            await Middleman.DeletePlayerAndReferences(p); 
            SelectedPlayer = null;
        }
        UsersPlayers = await Middleman.GetPlayers(SelectedUser.id);
        await InvokeAsync(StateHasChanged);
    }
    private async Task HidePlayer(Player p)
    {
        Player p2 = new Player(p);
        p2.is_hidden = true;
        await Middleman.UpdatePlayer(p, p2);
        await InvokeAsync(StateHasChanged);
    }
    private async Task UnhidePlayer(Player p)
    {
        Player p2 = new Player(p);
        p2.is_hidden = false;
        await Middleman.UpdatePlayer(p, p2);
        await InvokeAsync(StateHasChanged);
    }
    private async Task GetItemsBySimilar()
    {
        ItemsFound = await Middleman.GetItemsBySimilar(searchterm);
        await InvokeAsync(StateHasChanged);
    }
    private async Task SelectGift(Item itm)
    {
        SelectedResult = itm;
        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to give the player {SelectedPlayer.name} a {itm.name}?");
        if (confirmed)
        {
            await Middleman.GiveItem(itm.id, SelectedPlayer);
            PlayersInv = await Middleman.NewGetInvOfPlayer(SelectedPlayer);
            await InvokeAsync(StateHasChanged);
        }
    }
    private async Task MakeThisUserAnAdmin(User user)
    {
        bool confirmed; User temp;
        if (user.isadmin)
        {
            confirmed = await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to remove {user.username}'s admin powers?");
            temp = new User(user);
            user.isadmin = false;
            await Middleman.UpdateUser(temp,user);
        }
        else
        {
            confirmed = await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to make {user.username} an admin?");
            temp = new User(user);
            user.isadmin = true;
            await Middleman.UpdateUser(temp, user);
        }
        await InvokeAsync(StateHasChanged);
    }
    private async Task SetDisplayMode(int mode)
    {
        smode = (ScreenMode)mode;
        await InvokeAsync(StateHasChanged);
    }
    private async Task SelectMonster(Monster m)
    {
        if (SelectedMonster is null || SelectedMonster.id != m.id)
        {
            SelectedMonster = new Monster(m);
            Shadow = new Monster(m);
            MonsterAttacks = await Middleman.GetAllAttacksOfMonster(m.id);
        }
        else
        {
            SelectedItem = null;
            Shadow = null;
            MonsterAttacks = null;
        }
        await InvokeAsync(StateHasChanged);
    }
    private async Task UpdateMonster(Monster M)
    {
        await Middleman.UpdateMonster(Shadow, SelectedMonster);
        AllMonsters = await Middleman.GetMonsters(true);
        await InvokeAsync(StateHasChanged);
    }
    private async Task AddMonster(Monster M)
    {
        await Middleman.InsertGetMonster(M);
        AllMonsters = await Middleman.GetMonsters(true);
        await InvokeAsync(StateHasChanged);
    }
    private async Task SelectItemItem(Item itm)
    {
        if (PickedItem is null || PickedItem.id != itm.id)
        {
            PickedItem = new Item(itm);
            ShadowItem = new Item(itm);
            ItemAttacks = await Middleman.GetItemAttacksByItem(PickedItem.id);
        }
        else
        {
            PickedItem = null;
            ShadowItem = null;
            ItemAttackDummy = null;
        }
        await InvokeAsync(StateHasChanged);
    }
    private async Task UpdateItem(Item itm)
    {
        await Middleman.UpdateItem(ShadowItem, itm);
        AllItems = await Middleman.GetAllItems();
        await InvokeAsync(StateHasChanged);
    }
    private async Task CreateItem(Item itm)
    {
        await Middleman.InsertGetItem(itm);
        AllItems = await Middleman.GetAllItems();
        await InvokeAsync(StateHasChanged);
    }
    private async Task SelectItemAttack(Item_Attacks itmatk)
    {
        if (SelectedItemAttack is null || SelectedItemAttack.id != itmatk.id)
        {
            SelectedItemAttack = new Item_Attacks(itmatk);
            ShadowItemAttack = new Item_Attacks(itmatk);
            ItemAttackDummy.ItemID = itmatk.id;
        }
        else
        {
            SelectedItemAttack = null;
            ShadowItemAttack = null;
            ItemAttackDummy = new Item_Attacks();
        }
        await InvokeAsync(StateHasChanged);
    }
    private async Task CreateItemAttack(Item_Attacks itmatk)
    {
        await Middleman.InsertGetItemAttack(itmatk);
        if (ItemAttacks is null)
        {
            ItemAttacks = new List<Item_Attacks>();
        }
        ItemAttacks.Add(new Item_Attacks(itmatk));
        await InvokeAsync(StateHasChanged);
    }
    private async Task UpdateItemAttack(Item_Attacks itmatk)
    {
        await Middleman.UpdateItemAttack(ShadowItemAttack, itmatk);
        ItemAttacks = await Middleman.GetItemAttacksByItem(SelectedItem.Id);
        await InvokeAsync(StateHasChanged);
    }
    private async Task SelectMonsterAttack(Monster_Attacks matk)
    {
        if (SelectedMonsterAttack is null || SelectedMonsterAttack.id != matk.id)
        {
            SelectedMonsterAttack = new Monster_Attacks(matk);
            ShadowMonsterAttack = new Monster_Attacks(matk);
        }
        else
        {
            SelectedMonsterAttack = null;
            ShadowMonsterAttack = null;
        }
        await InvokeAsync(StateHasChanged);
    }
    private async Task CreateMonsterAttack(Monster_Attacks matk)
    {
        await Middleman.InsertGetMonsterAttack(matk);
        if (MonsterAttacks is null)
        {
            MonsterAttacks = new List<Monster_Attacks>();
        }
        MonsterAttacks.Add(new Monster_Attacks(matk));
        await InvokeAsync(StateHasChanged);
    }
    private async Task UpdateMonsterAttack(Monster_Attacks matk)
    {
        await Middleman.UpdateMonsterAttack(ShadowMonsterAttack, matk);
        MonsterAttacks = await Middleman.GetAllAttacksOfMonster(matk.monsterId);
        await InvokeAsync(StateHasChanged);
    }
    private async Task SelectAttack(Attack atk)
    {
        if (SelectedAttack is null || SelectedAttack.id != atk.id)
        {
            SelectedAttack = new Attack(atk);
            ShadowAttack = new Attack(atk);
        }
        else
        {
            SelectedAttack = null;
            ShadowAttack = null;
        }
        await InvokeAsync(StateHasChanged);
    }
    private async Task CreateAttack(Attack atk)
    {
        await Middleman.InsertGetAttack(atk);
        if (AllAttacks is null)
        {
            AllAttacks = new List<Attack>();
        }
        AllAttacks.Add(new Attack(atk));
        await InvokeAsync(StateHasChanged);
    }
    private async Task UpdateAttack(Attack atk)
    {
        await Middleman.UpdateAttack(ShadowAttack, atk);
        AllAttacks = await Middleman.GetAllAttacks();
        await InvokeAsync(StateHasChanged);
    }
}
