@page "/Dungeon"
@using DBL
@using Models
@inject NavigationManager NavMan
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject ProtectedSessionStorage Session
@using System.Media;
@using System.Text.Json;



<ul>
    @if (LoggedUser is not null)
    {
        <li>
            <button @onclick="Back" class="perma_name generic-btn">
                Go back to the lobby
            </button>
        </li>


        <navname>
            <div class="perma_name generic-btn" style="width: 800px;">
                The Dungeon
            </div>
        </navname>
    }
</ul>

@if (LoggedUser is not null)
{
    <table>
        <td style="background-color:rgba(51, 51, 51, 0.25); max-width:15%">
            @if (Selected is not null)
            {
                <div class="generic-btn">
                    <div style="font-family:Verdana; font-size:20px;">
                        Player details:
                    </div>
                </div>
                <br />
                <div class="generic-btn" style="padding:10px;">
                    <div style="font-family:Forte; text-align:center; font-size:30px;">
                        @Selected.name
                    </div>
                    <div style="font-family:Forte; text-align:center; font-size:20px;">
                        Character stats: <br />
                        HP: @Selected.hp <br />
                        Coins: @Selected.coins <br />
                        Mana: @Selected.mana <br />
                    </div>
                </div>
                <br />
                
            }
        </td>
        <td style="background-color: rgba(51,51,51,0.25); max-width:45%">
            <tr>
                @if (current is not null && Ghost is not null)
                {
                    <div style="display:flex; flex-flow: row wrap; overflow:auto; max-height:750px; max-width: 600px;">
                        <div class="generic-btn" style="vertical-align:middle;">
                            <div style="font-family:Forte; font-size:30px;vertical-align:middle;">
                                <img src=@GetImageIcon(current.filepath) />
                                @current.name
                            </div>
                            <div style="font-family:Forte; text-align:center; font-size:20px;">
                                HP: <span style="color:@sNachlit">@current.hp</span> / @Ghost.hp
                                Defense: @current.defense <br />
                                Rarity: @GetRarityString(current.rarity) <br />
                                <div style="font-size:15px; font-family:sans-serif">
                                    @current.description
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </tr>
            <tr>
                <div style="display:flex; flex-flow: row wrap; overflow:auto; max-height:350px;">
                    @if(PlayerInventory is not null)
                    {
                        @foreach (Dictionary<string, object> item in PlayerInventory)
                        {
                            bool isHiddenInv = ((JsonElement)item["Inv_IsHidden"]).GetBoolean();
                            bool isHiddenItem = ((JsonElement)item["Itm_IsHidden"]).GetBoolean();
                            @if (!isHiddenInv && !isHiddenItem)
                            {
                                <button class="dropdown" style="padding: 5px 5px 5px 5px; border:2px; border-color:black;" @onclick="() => SelectItem(item)">
                                    <div class="perma_name dropbtn" style="font-family:Verdana">
                                        @item["Name"] | Level @item["Item_Level"]
                                    </div>
                                </button>
                            }
                        }
                        <button class="dropdown" style="padding: 5px 5px 5px 5px; border:2px; border-color:black;" @onclick="Escape">
                            <div class="perma_name dropbtn" style="font-family:Verdana">
                                Escape?
                            </div>
                        </button>
                    }
                </div>
            </tr>
        </td>
        <td style="background-color: rgba(51, 51, 51, 0.25); max-width:50%; vertical-align:central"> 
            @if (SelectedItem is not null && current is not null)
            {
                <div class="generic-btn perma_name">
                    Attacks you can do with @SelectedItem["Name"] <br />
                    Click an attack to execute it
                </div> <br />
                @foreach (Dictionary<string,object> ItmAtk in ItemAttacks)
                {
                    <button class="generic-btn" @onclick="() => DamageMonster(ItmAtk)">
                        <div style="font-family:Forte; text-align:center; font-size:20px;">
                            @ItmAtk["Name"] -- @ItmAtk["Damage"] damage <br />
                            Lasts for @ItmAtk["Duration"] turns <br />
                        </div>
                    </button>
                }
            }
        </td>
    </table>
}



@code {
    string sNachlit = "#000000";
    Monster current; Monster Ghost;
    Player Selected; User LoggedUser;
    Dictionary<string, object> SelectedItem;
    Random Jerry = new Random();
    List<Dictionary<string, object>> PlayerInventory = new List<Dictionary<string, object>>();
    List<Dictionary<string, object>> PlayerEntries = new List<Dictionary<string, object>>();
    List<Element> Elements = new List<Element>();
    List<Item_Type_Name> Item_Type_Names = new List<Item_Type_Name>();
    List<Dictionary<string, object>> ItemAttacks = new List<Dictionary<string, object>>();
    List<Dictionary<string, object>> MonsterAttacks = new List<Dictionary<string, object>>();
    Dictionary<string, object> SelectedAttack = new Dictionary<string, object>();
    [Inject] IJSRuntime JS { get; set; } = default!;
    protected override async Task OnInitializedAsync()
    {
        try
        {
            current = await Middleman.GetRandomMonster(0); Ghost = new Monster(current);
            var GetPlayer = await Session.GetAsync<Player>("Selected player");
            if (GetPlayer.Success) { Selected = new Player(GetPlayer.Value); }
            var GetUser = await Session.GetAsync<User>("Logged user");
            if (GetUser.Success) { LoggedUser = new User(GetUser.Value); }
            var GetInventory = await Session.GetAsync<List<Dictionary<string, object>>>("Player's inventory");
            if (GetInventory.Success) { PlayerInventory = GetInventory.Value; }
            var GetEntries = await Session.GetAsync<List<Dictionary<string, object>>>("Player's entries");
            if (GetEntries.Success) { PlayerEntries = GetEntries.Value; }
            Elements = await Middleman.GetAllElements();
            Item_Type_Names = await Middleman.GetAllItem_Type_Names();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            await Task.Delay(150);
            await Back();
        }
    }
    private async Task SelectMonster()
    {
        current = await Middleman.GetRandomMonster(current.id);
        Ghost = new Monster(current);
        MonsterAttacks = await Middleman.GetMonsterAttacks(Ghost);
        await InvokeAsync(StateHasChanged);
    }
    private async Task DamageMonster()
    {
        int damage = Jerry.Next(1, 6);
        damage -= current.defense;
        if (damage <= 0) damage = 1;
        current.hp -= damage;
        if (current.hp <= 0) 
        { 
            if (Jerry.Next(0, 1001) == 0)
            {
                string filepath = Path.Combine(AppContext.BaseDirectory, "..", "..", "..", "wwwroot", "misc", "TheFunnyAudio.wav");
                SoundPlayer player = new SoundPlayer(filepath);
                try { player.Play(); }
                catch (Exception e){}
            }
            await OnMonsterKilled();
            await SelectMonster(); 
        }
    }
    private async Task DamageMonster(Dictionary<string,object> attack)
    {
        int basedamage = Convert.ToInt32(attack["Damage"].ToString());
        if (basedamage < 0)
        {
            basedamage -= Convert.ToInt32(SelectedItem["ItemIncrement"].ToString()) * Convert.ToInt32(SelectedItem["Item_Level"].ToString());
            Selected.hp -= basedamage;
            int stackamount = Convert.ToInt32(SelectedItem["Amount"].ToString());
            await Middleman.UseItem(SelectedItem);
            stackamount--;
            SelectedItem["Amount"] = stackamount;
            if (stackamount <= 0) { SelectedItem = null; return; }
            foreach (Dictionary<string,object> eeee in PlayerInventory)
            {
                if (eeee["InventoryID"] == SelectedItem["InventoryID"])
                {
                    eeee["Amount"] = SelectedItem["Amount"];
                    await MonsterTurn();
                    break;
                }
            }
        }
        else
        {
            int amplifiedDamage = basedamage + (Convert.ToInt32(SelectedItem["ItemIncrement"].ToString()) * Convert.ToInt32(SelectedItem["Item_Level"].ToString()));
            int damage = Jerry.Next((int)(amplifiedDamage * 0.9), (int)(amplifiedDamage * 1.1));
            damage -= current.defense;
            if (damage <= 0) damage = 1; //Pity mechanic
            current.hp -= damage;
            if (current.hp <= 0)
            {
                if (Jerry.Next(0, 1001) == 0)
                {
                    string filepath = Path.Combine(AppContext.BaseDirectory, "..", "..", "..", "wwwroot", "misc", "TheFunnyAudio.wav");
                    SoundPlayer player = new SoundPlayer(filepath);
                    try { player.Play(); }
                    catch (Exception e) { }
                }
                await OnMonsterKilled();
                await SelectMonster();
            }
            else
            {
                double HPPrecentage = ((double)current.hp / (double)Ghost.hp) * 100;
                if (HPPrecentage > 50) { sNachlit = "#000000"; }
                else if (HPPrecentage <= 30) { sNachlit = "#fca045"; }
                else if (HPPrecentage <= 15) { sNachlit = "#cc0000"; }
                await MonsterTurn();
            }
        }
    }
    private async Task MonsterTurn()
    {
        Dictionary<string, object> AttackToDo = new Dictionary<string, object>();
        if (MonsterAttacks.Count > 1) { AttackToDo = MonsterAttacks[Jerry.Next(0, MonsterAttacks.Count)]; }
        else { AttackToDo = MonsterAttacks[0]; }
        int basedamage = Convert.ToInt32(AttackToDo["Damage"].ToString());
        if (basedamage < 0) { basedamage = 1; }
        Selected.hp -= basedamage;
        if (Selected.hp <= 0) await OnPlayerDeath();
    }
    private async Task Back() 
    {
        var GetPlayer = await Session.GetAsync<Player>("Selected player");
        if (GetPlayer.Success) 
        { 
            await Middleman.UpdatePlayer(GetPlayer.Value,Selected); 
        } 
        NavMan.NavigateTo("/Lobby"); 
    }
    private async Task Escape()
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to try to escape?");
        if (confirmed)
        {
            int chance = Jerry.Next(0, 7);
            if (chance == 0)
            {
                await JS.InvokeVoidAsync("alert", "You succeeded in escaping! You'll return to the lobby.");
                await Back();
            }
            else
            {
                await JS.InvokeVoidAsync("alert", "You failed your escape! It's now the monster's turn.");
                await MonsterTurn();
            }
        }
        else
        {
            await JS.InvokeVoidAsync("alert", "You chose to not escape, the game will continue on the monster's turn.");
            await MonsterTurn();
        }
    }
    private string GetImageIcon(String s) { return $"/img/{s}"; }
    private string GetRarityString(int Rarity)
    {
        string ret = string.Empty;
        for (int i = 0; i < Rarity; i++)
        {
            ret += "⭐";
        }
        return ret;
    }
    private bool IsItemNotArmor(Dictionary<string,object> item)
    {
        if (Convert.ToInt32(item["ItemType"].ToString()) == 4) { return false; }
        return true;
    }
    private async Task OnMonsterKilled()
    {
        Selected = await Middleman.AwardPlayerForKill(Ghost, Selected);
        await Middleman.RegisterEntry(Selected,Ghost,PlayerEntries);
        var GetPlayer = await Session.GetAsync<Player>("Selected player");
        if (GetPlayer.Success)
        {
            await Middleman.UpdatePlayer(GetPlayer.Value, Selected);
        }
    }
    private async Task SelectItem(Dictionary<string,object> itm)
    {
        int itemid = ((JsonElement)itm["ItemID"]).GetInt32();
        if (SelectedItem is null || ((JsonElement)SelectedItem["ItemID"]).GetInt32() != itemid)
        {
            SelectedItem = itm;
            ItemAttacks = await Middleman.GetAttacksOfItem(itemid);
        }
        await InvokeAsync(StateHasChanged);
    }
    private async Task OnPlayerDeath()
    {
        Random Jerry = new Random();
        double DiffMultiplier = ((double)((Ghost.rarity * 100 + Ghost.defense * 10) / 10)) / 100 + 1;
        int BossMultiplier = 10 * Ghost.isboss;
        int RawCoin = Jerry.Next(1 + BossMultiplier, (int)(Math.Pow(10 + BossMultiplier, 2)) + 1);
        double TotalCoin = RawCoin * DiffMultiplier;
        await JS.InvokeVoidAsync("confirm", $"You have died! You lost {(int)TotalCoin} coins and you will return to the lobby now.");
        Selected.coins -= (int)TotalCoin;
        var GetPlayer = await Session.GetAsync<Player>("Selected player");
        if (GetPlayer.Success)
        {
            await Middleman.UpdatePlayer(GetPlayer.Value, Selected);
        }
        NavMan.NavigateTo("/Lobby");
    }
}