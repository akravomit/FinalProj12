@page "/Testuploads"
@using DBL
@using Models
@inject NavigationManager NavMan
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject ProtectedSessionStorage Session
@inject IWebHostEnvironment Environment

<ul>
    <ui><div class="generic-btn perma_name">Test uploads page</div></ui>
    <navname><button @onclick="Back" class="generic-btn"><div class="perma_name">Go back to the main page</div></button></navname>
</ul>

<h2>Upload WebP Image</h2>

<div class="generic-btn">
    <InputFile OnChange="HandleFileSelected" accept="image/webp" />

    <div style="margin-top: 15px;">
        <label>Folder Name (inside wwwroot/img, default will be misc):</label>
        <input type="text" @bind="FolderName" />
        <br />
        <label for="FileName">Enter a name for the file</label>
        <input id="FileName" type="text" @bind="FileName" />
        <small> (letters, numbers, dashes and underscores recommended)</small>
    </div>

    <button @onclick="UploadFile" style="margin-top: 20px;" disabled="@isUploading">
        @(isUploading ? "Uploading..." : "Upload Image")
    </button>
</div>

@if (!string.IsNullOrEmpty(Message))
{
    <p style="color: green;">@Message</p>
}

@if (!string.IsNullOrEmpty(Error))
{
    <p style="color: red;">@Error</p>
}

<style>
    body {
        background-image: url('/img/bg/library.png');
    }
</style>

@code {
    User loggeduser;
    private async Task Back() { NavMan.NavigateTo("/"); }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var tmp = await Session.GetAsync<User>("Logged user");
                if (tmp.Success)
                {
                    loggeduser = tmp.Value;
                    if (!loggeduser.isadmin) { await Back(); }
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (Exception ex)
            {
                await Task.Delay(150);
                await Back();
            }
        }
    }
    private IBrowserFile? selectedFile;
    private string FolderName { get; set; } = "";
    private string FileName = "";
    private string Message { get; set; } = "";
    private string Error { get; set; } = "";
    private bool isUploading = false;

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        Message = "";
        Error = "";
    }

    private async Task UploadFile()
    {
        if (selectedFile == null)
        {
            Error = "Please select a file.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (!selectedFile.ContentType.Equals("image/webp", StringComparison.OrdinalIgnoreCase))
        {
            Error = "Only .webp images are allowed.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        isUploading = true;
        Message = "";
        Error = "";

        try
        {
            // Sanitize folder name
            var safeFolder = string.IsNullOrWhiteSpace(FolderName) ? "misc" : FolderName.Trim();
            safeFolder = Path.GetInvalidFileNameChars()
                             .Aggregate(safeFolder, (current, c) => current.Replace(c, '_'));

            var uploadPath = Path.Combine(Environment.WebRootPath, "img", safeFolder);

            if (!Directory.Exists(uploadPath))
            {
                Directory.CreateDirectory(uploadPath);
            }

            //var fileName = selectedFile.Name;
            var fileName = string.IsNullOrEmpty(FileName) ? selectedFile.Name : FileName + ".webp";
            var fullPath = Path.Combine(uploadPath, fileName);

            await using var stream = new FileStream(fullPath, FileMode.Create);
            await selectedFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(stream);

            Message = $"Image uploaded successfully to: img/{safeFolder}/{fileName}";
        }
        catch (Exception ex)
        {
            Error = $"Upload failed: {ex.Message}";
        }
        finally
        {
            isUploading = false;
            await InvokeAsync(StateHasChanged);
        }
    }
}
