@page "/"
@using DBL
@using Models
@inject NavigationManager NavMan
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject ProtectedSessionStorage Session
@using System.Timers;

<ul>
    @if (LoggedUser is null)
    {
        <li>
            <button @onclick="() => Navigate('L')" class="generic-btn">
                <div class="perma_name">
                    Login
                </div>
            </button>
        </li>
        <li>
            <button @onclick="() => Navigate('R')" class="generic-btn">
                <div class="perma_name">
                    Register
                </div>
            </button>
        </li>
        <navname>
            <div class="perma_name generic-btn">
                Hello user!
            </div>
        </navname>
    }
    else
    {
        <li>
            <button @onclick="() => Navigate('U')" class="generic-btn">
                <div class="perma_name">
                    Manage your user
                </div>
            </button>
        </li>
        @if (LoggedUser.isadmin)
        {
            <li>
                <button @onclick="() => Navigate('M')" class="generic-btn">
                    <div class="perma_name">
                        Manager page
                    </div>
                </button>
            </li>
        }
        <li>
            <button @onclick="() => Navigate('G')" class="generic-btn">
                <div class="perma_name">
                    Go to the lobby
                </div>
            </button>
        </li>
        <li>
            <button @onclick="Log_Out_Async" class="generic-btn">
                <div class="perma_name">
                    Log out of your account
                </div>
            </button>
        </li>
        <navname>
            <div class="perma_name generic-btn">
                Hello, @LoggedUser.username!
            </div>
        </navname>
    }
</ul>

<table>
    <td style="background-color:rgba(51, 51, 51, 0.25); max-width:300px; max-height:650px;">
        @if (renderads)
        {
            <div class="generic-btn" style="padding:10px;">
                <div style="font-family:Forte; text-align:center; font-size:30px;">
                    And now, an ad from our sponsors:
                    @if (ad is not null)
                    {
                        @ad.headline
                    }
                </div>
                <div style="text-align:center; font-size:15px;">
                    @if (ad is not null)
                    {
                        @ad.body
                    }
                    @if (AdRequestFailed)
                    {
                        <div>
                            Hmm... we are having some issues on our end. Please check back later to see our ads later! They're vital for this website to run!
                        </div>
                    }
                </div>
            </div>
        }
    </td>
</table>



@code {
    protected User LoggedUser;
    bool renderads = false; bool AdRequestFailed = false;
    HttpClient client = new HttpClient();
    Advertisement ad = new Advertisement();
    async Task Navigate(char c)
    {
        string dest = "/";
        switch (c)
        {   
            case 'L': dest = "Login"; break;
            case 'R': dest = "Register"; break;
            case 'U': dest = "Update"; break;
            case 'P': dest = "Players"; break;
            case 'M': dest = "Manage"; break;
            case 'G': dest = "Lobby"; break;
        }
        NavMan.NavigateTo(dest);
    }
    async Task Log_Out_Async()
    {
        await Session.DeleteAsync("Logged user");
        await Session.DeleteAsync("Selected player");
        LoggedUser = null;
        await InvokeAsync(StateHasChanged);
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var tmp = await Session.GetAsync<User>("Logged user");
            if (tmp.Success) { LoggedUser = tmp.Value; }
            renderads = true;
            await InvokeAsync(StateHasChanged);
            await CycleAds();

            Timer timerPullAdd;
            timerPullAdd = new System.Timers.Timer();
            timerPullAdd.Interval = 30000;
            timerPullAdd.Elapsed += async (sender, e) => await CycleAds();
            timerPullAdd.AutoReset = true;
            timerPullAdd.Enabled = true;
        }
    }
    async Task CycleAds()
    {
        try
        {
            ad = await client.GetFromJsonAsync<Advertisement>("https://localhost:7094/api/Annoyingads/GetARandomAd");
            if (ad.ToString() == "{}") AdRequestFailed = true;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            AdRequestFailed = true;
        }
    }
}
