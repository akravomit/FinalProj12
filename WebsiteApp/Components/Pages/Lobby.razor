@page "/Lobby"
@using DBL
@using Models
@inject NavigationManager NavMan
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject ProtectedSessionStorage Session

<ul>
    @if(LoggedUser is not null)
    {
        <li>
            <button @onclick="Back" class="perma_name generic-btn">
                Go back to the main menu
            </button>
        </li>

        @if(Selected is not null)
        {
            <navname>
                <div class="perma_name generic-btn">
                    Viewing things as @Selected.name
                </div>
            </navname>
        }
        <navname>
            <div class="perma_name generic-btn">
                Hello, @LoggedUser.username!
            </div>
        </navname>
    }
</ul>

@if(LoggedUser is not null)
{
    <table>
        <td style="background-color:rgba(51, 51, 51, 0.25); max-width:15%">
            @if (Playerlist is not null)
            {
                <div class="dropdown" style="padding: 20px 0px 40px 20px;">
                    <button class="dropbtn">Select a character to view</button>
                    <div class="dropdown-content" style="max-height:80px; overflow:auto;">
                        @foreach (Player plr in Playerlist)
                        {
                            <button class="generic-btn" @onclick="() => Select_Player(plr)">@plr.name</button>
                        }
                    </div>
                </div>
            }
            <br />
            <form @onsubmit="CreatePlr" style="padding: 20px 0px 30px 20px;">
                @* <div class="generic-btn" style="font-family:Forte; text-align:center;">Create a new character!</div> <br /> *@
                <input class="generic-btn" @bind-value="playername" placeholder="Enter a name for a new character" style="font-size:20px; font-family:Forte;" required pattern="^.{0,20}$" title="Please input a name under 20 characters long" />
                <br />
                <button class="generic-btn" type="submit">
                    <div class="perma_name" style="font-size:20px">Create the new character!</div>
                </button>
            </form>
            @if(Selected is not null)
            {
                <button class="generic-btn" style="padding:10px;">
                    <div style="font-family:Forte; text-align:center; font-size:30px;">
                        @Selected.name
                    </div>
                    <div style="font-family:Forte; text-align:center; font-size:20px;">
                        Character stats: <br />
                        HP: @Selected.hp <br />
                        Coins: @Selected.coins <br />
                        Mana: @Selected.mana <br />
                    </div>
                </button>
            }
        </td>
        <td style="background-color:rgba(51, 51, 51, 0.25); max-width:35%; padding: 20px 0px 30px 20px;">
            @if (Selected is not null)
            {
                <div class="generic-btn">
                    <div class="header">
                        The items you own:
                    </div>
                </div>
                <br />
                <div style="display:flex; flex-flow: column wrap; overflow:auto; max-height:730px;">
                    @foreach (Dictionary<string,object> inv in PlayerFullInv)
                    {
                        <button class="generic-btn" style="padding: 10px;">
                            <div style="font-family:Forte; text-align:center; font-size:30px;">
                                @*Image icon goes here*@
                                @inv["Name"]
                            </div>
                            <div style="font-family:Forte; text-align:center; font-size:20px;">
                                Item info: <br />
                                Item Level: @inv["Item_Level"] | Amount owned: @inv["Amount"] <br />
                                Item rarity: @GetRarityString(Convert.ToInt32(inv["Rarity"])) | Value per item: @inv["Value"]/@inv["MaxStack"] <br />
                            </div>
                        </button>
                    }
                </div>
            }
        </td>
        <td style="background-color:rgba(51, 51, 51, 0.25); max-width:60%; padding: 0px 0px 30px 20px;">
            @if (Selected is not null)
            {
                <div class="generic-btn">
                    <div class="header">
                        All the monsters you killed:
                    </div>
                </div>
                <div style="display:flex; flex-flow:column wrap; overflow:auto; max-width:inherit; max-height:730px">
                    @foreach (Dictionary<string,object> Entr in PlayerFullEntr)
                    {
                        <button class="generic-btn" style="padding:10px;">
                            <div style="font-family:Forte; text-align:center; vertical-align:middle; font-size:30px;">
                                <img src=@GetImageIcon(Entr["FilePath"].ToString()) />
                                @Entr["Name"]
                            </div>
                            <div style="font-family:Forte; text-align:center; font-size:20px;">
                                Entry info: <br />
                                Killed on @Entr["DateSlain"]<br /> The first time was @DateTime.Today.Subtract((DateTime)Entr["DateSlain"]).Days days ago <br />
                                Times killed: @Entr["TimesKilled"] | Rarity: @GetRarityString(Convert.ToInt32(Entr["Rarity"].ToString())) stars <br />
                            </div>
                        </button>
                    }
                </div>
            }
        </td>
        <td style="background-color:rgba(51, 51, 51, 0.25); max-width:20%;">
            @if (Selected is not null)
            {
                <button class="generic-btn" @onclick="() => Goto('D')">
                    <div class="perma_name" style="font-size:25px;">
                        Go to the dungeon with your selected character
                    </div>
                </button>
            }
        </td>
    </table>
}


@code {
    User LoggedUser; List<Player> Playerlist; Player Selected;
    string playername; string Dungeon = "Dungeon";
    List<Dictionary<string, object>> PlayerFullInv;
    List<Dictionary<string, object>> PlayerFullEntr;
    Random Jerry = new Random();
    protected override async Task OnInitializedAsync()
    {
        var tmp = await Session.GetAsync<User>("Logged user");
        if (tmp.Success)
        {
            LoggedUser = tmp.Value;
            Playerlist = await Middleman.GetPlayers(LoggedUser.id);
        }
        await InvokeAsync(StateHasChanged);
    }
    private async Task Back() { NavMan.NavigateTo("/"); }
    private async Task Select_Player(Player plr)
    {
        Selected = new Player(plr);
        PlayerFullEntr = new List<Dictionary<string, object>>();
        PlayerFullInv = new List<Dictionary<string, object>>();
        PlayerFullInv = await Middleman.NewGetInvOfPlayer(Selected);
        PlayerFullEntr = await Middleman.NewGetEntriesOfPlayer(Selected);
        StateHasChanged();
    }
    private async Task CreatePlr()
    {
        Player tmp = new Player(playername,LoggedUser.id);
        await Middleman.InsertGetPlayer(playername, LoggedUser.id);
        if (Playerlist is null)
        {
            Playerlist = new List<Player>();
        }
        Playerlist.Add(tmp);
        List<int> ItemsToGift = new List<int>() { 1, 5, 19 };
        await Middleman.GiftItem(ItemsToGift[Jerry.Next(0, ItemsToGift.Count)], tmp);
    }
    private string GetImageIcon(String s) { return $"/img/{s}"; }
    private async Task Goto(char dest)
    {
        await Session.SetAsync("Selected player", Selected);
        await Session.SetAsync("Player's inventory", PlayerFullInv);
        await Session.SetAsync("Player's entries", PlayerFullEntr);
        switch (dest)
        {
            case 'D': NavMan.NavigateTo(Dungeon); break;

            default: break;
        }
    }
    private string GetRarityString(int Rarity)
    {
        string ret = string.Empty;
        for (int i = 0; i < Rarity; i++)
        {
            ret += "⭐";
        }
        return ret;
    }
}
